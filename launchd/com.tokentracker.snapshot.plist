<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tokentracker.snapshot</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>__AUDITOR_DIR__/snapshot.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__AUDITOR_DIR__</string>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>23</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__AUDITOR_DIR__/logs/snapshot.log</string>
  <key>StandardErrorPath</key>
  <string>__AUDITOR_DIR__/logs/snapshot.err</string>
</dict>
</plist>
